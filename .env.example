# Database
POSTGRES_DB=movie_app
POSTGRES_USER=movie_app
POSTGRES_PASSWORD=change_me

# Redis
REDIS_PASSWORD=change_me

# TMDB API — get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

# Seed endpoint protection — leave blank to allow unauthenticated seeding (dev only)
SEED_API_KEY=change_me
